# === API KEYS ===
# Get your Google AI key from: https://aistudio.google.com/apikey
# Get your HuggingFace key from: https://huggingface.co/settings/tokens
#
# IMPORTANT: Copy this file to .env and fill in your actual keys
# NEVER commit your actual .env file to git!
# The .gitignore file is set up to exclude .env automatically.
#
# BOTH KEYS ARE FREE:
# - Google AI Studio gives you a free API key with generous limits (15 RPM)
# - HuggingFace gives you a free token for the Inference API

GOOGLE_API_KEY=your_key_here
HUGGINGFACE_API_KEY=your_key_here
